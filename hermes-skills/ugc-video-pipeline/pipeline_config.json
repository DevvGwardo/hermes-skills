{
  "_version": "1.0",
  "_description": "Default configuration for the UGC Video Pipeline orchestrator",

  "paths": {
    "skill_dir": "~/.hermes/skills/ugc-video-pipeline",
    "output_dir": "~/.hermes/ugc-output",
    "models_dir": "~/models",
    "comfyui_dir": "~/models/ComfyUI",
    "reference_audio": "",
    "character_image": "",
    "luts_dir": "~/.hermes/skills/ugc-video-pipeline/luts",
    "workflows_dir": "~/.hermes/skills/ugc-video-pipeline/workflows",
    "caption_style": "~/.hermes/skills/ugc-video-pipeline/caption_style.json"
  },

  "llm": {
    "provider": "ollama",
    "model": "llama3.1:70b",
    "endpoint": "http://localhost:11434/api/generate",
    "api_key_env": "",
    "timeout_secs": 120
  },

  "comfyui": {
    "host": "http://localhost:8188",
    "timeout_secs": 600
  },

  "voice_clone": {
    "enabled": true,
    "language": "en"
  },

  "talking_head": {
    "enabled": true,
    "backend": "auto",
    "aspect_ratio": "9:16",
    "avatar_prompt": "professional headshot photo of a friendly diverse person, frontal face, studio lighting, high quality portrait",
    "avatar_model": "sd-xl"
  },

  "scene_video": {
    "enabled": true,
    "model": "wan22",
    "duration": 5,
    "resolution": [1280, 720],
    "seed": 42
  },

  "compose": {
    "enabled": true,
    "layout": "picture_in_picture",
    "lut": "cinematic",
    "normalize_audio": true,
    "target_lufs": -14.0,
    "fade_in": 0.5,
    "fade_out": 0.5,
    "caption_text": true
  },

  "defaults": {
    "duration": 30,
    "tone": "casual",
    "aspect_ratio": "9:16",
    "video_format": "9:16"
  }
}
